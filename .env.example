# Server (default 3001 in code — leaves 3000 free for Next.js etc.; override for Combell/production)
PORT=3001

# Optional: 301 redirect Host www.<host> → https://<host> (preserves path and query)
# CANONICAL_HOST=log.tabulas.eu

# Optional: override persisted Turtle file (default: ./data/products.ttl)
# DPP_GRAPH_PATH=/var/lib/dpp-event/products.ttl
# Tiny fixture for UI smoke tests (two events, one product): ./data/graph-minimal.ttl

# Enables DELETE /graph, dashboard “Clear graph”, and `npm run clear:graph` against a running API.
# Local dev: use the value below so one command clears memory + file + timeline. Use a strong random secret in production.
DPP_GRAPH_RESET_SECRET=dev-local-reset

# Optional: base URL for `npm run clear:graph` to hit a running API (default http://127.0.0.1:$PORT).
# DPP_API_ORIGIN=http://127.0.0.1:3002

# Optional: text shown on GET / (dashboard) linking to user-facing sites
# DASHBOARD_FRONTENDS=https://aiactscan.eu · https://tabulas.eu

# IOTA Rebased (testnet)
IOTA_RPC_URL=https://api.testnet.iota.cafe
IOTA_PRIVATE_KEY=
IOTA_NETWORK=testnet

# Browser origins allowed to call this API (comma-separated). No path — use scheme+host only.
# Example: EU AI Act scan app on Vercel + Tabulas read layer
CORS_ORIGINS=https://aiactscan.eu,https://tabulas.eu

# Legacy: single origin (used only if CORS_ORIGINS is unset)
# TABULAS_ORIGIN=https://tabulas.eu

# Frontend (Vite — set in root .env for dev/build; optional on Combell if you bake env at build time)
# GS1 Digital Link URLs in the graph then open YOUR page with ?uri=<canonical> instead of only the resolver.
# VITE_IDENTIFIER_DOCS_BASE=https://tabulas.eu/docs/your-dpp-identifiers-page

# Solid Pod (Athumi/Kvasir), private credential storage
SOLID_POD_URL=
SOLID_OIDC_ISSUER=
